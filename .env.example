# Copy to .env and fill in real values

# Get this from @BotFather
BOT_TOKEN=123456:ABC-DEF_your_token_here

# Comma-separated Telegram user IDs with staff access.
# First ID is the owner (full access + can assign roles). Others default to reviewer.
# Roles: manager | reviewer | support | viewer
# Assign in bot: Settings → دسترسی ادمین‌ها, or /setadminrole <user_id> <role>
ADMIN_IDS=123456789,987654321

# Path to the SQLite database file (relative to project root)
DB_PATH=netfly.db

# SMS.ir Configuration (Optional)
# API key from app.sms.ir developer portal
SMS_API_KEY=your_sms_ir_api_key_here
# Sender line number (required for bulk send)
SMS_LINE_NUMBER=your_sms_ir_line_number_here
# Comma-separated admin mobile numbers to receive SMS notifications (e.g. 09123456789,09129876543)
SMS_ADMIN_MOBILES=09123456789
# Template ID from sms.ir panel (if template-based/verify SMS is preferred)
# Template should contain parameters: ORDERID, PRICE, LOCATION
SMS_TEMPLATE_ID=
