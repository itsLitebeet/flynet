# Copy to .env and fill in real values

# Get this from @BotFather
BOT_TOKEN=123456:ABC-DEF_your_token_here

# Comma-separated Telegram user IDs that should have admin powers.
# To get your own id, message @userinfobot in Telegram.
ADMIN_IDS=123456789

# Path to the SQLite database file (relative to project root)
DB_PATH=netfly.db
